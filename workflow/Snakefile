"""
Usage:
    # local
    uv run just local-run

    # SLURM
    uv run just slurm-run

    # dry run
    uv run just dry-run
"""

# shared config
include: "rules/common.smk"

# include rule files
include: "rules/preprocessing.smk"
include: "rules/training.smk"
include: "rules/inference.smk"
if STAGES.get("accessibility_scores", False):
    include: "rules/accessibility_scores.smk"
if STAGES.get("benchmark", False):
    include: "rules/benchmark.smk"


# build final targets
TARGETS = []

if STAGES.get("generate_negatives", False):
    TARGETS.append(f"{TRAIN_DHS_DIR}.negatives_done")

if STAGES.get("collect_data", False):
    TARGETS += expand(
        f"{TRAIN_OUTPUT_DIR}{{sample}}__{{dhs_file}}_rebinned.npy",
        sample=SAMPLES, dhs_file=DHS_FILES,
    )

if STAGES.get("train", False):
    TARGETS.append(TRAINING.get("save_checkpoint", MODEL["checkpoint"]))

if STAGES.get("inference", False):
    TARGETS += expand(
        f"{ACCESSIBILITY_DIR}{{sample}}__{{dhs_file}}_score.txt",
        sample=INFERENCE_SAMPLES, dhs_file=INFERENCE_DHS_FILES,
    )
    TARGETS += expand(
        f"{ACCESSIBILITY_DIR}{{sample}}__{{dhs_file}}.cov.txt",
        sample=INFERENCE_SAMPLES, dhs_file=INFERENCE_DHS_FILES,
    )

if STAGES.get("accessibility_scores", False):
    TARGETS += expand(
        f"{ACCESSIBILITY_DIR}{{sample}}__{{dhs_file}}_downsampled_lwps.npy",
        sample=INFERENCE_SAMPLES, dhs_file=INFERENCE_DHS_FILES,
    )
    TARGETS += expand(
        f"{ACCESSIBILITY_DIR}{{sample}}__{{dhs_file}}_downsampled_ocf.npy",
        sample=INFERENCE_SAMPLES, dhs_file=INFERENCE_DHS_FILES,
    )
    TARGETS += expand(
        f"{ACCESSIBILITY_DIR}{{sample}}__{{dhs_file}}_downsampled_fdi.npz",
        sample=INFERENCE_SAMPLES, dhs_file=INFERENCE_DHS_FILES,
    )
    TARGETS += expand(
        f"{ACCESSIBILITY_DIR}{{sample}}__{{dhs_file}}_downsampled_ifs.npz",
        sample=INFERENCE_SAMPLES, dhs_file=INFERENCE_DHS_FILES,
    )
    TARGETS += expand(
        f"{ACCESSIBILITY_DIR}{{sample}}__{{dhs_file}}_downsampled_pfe.npz",
        sample=INFERENCE_SAMPLES, dhs_file=INFERENCE_DHS_FILES,
    )

if STAGES.get("benchmark", False):
    TARGETS += expand(
        f"{FINAL_MATRICES_DIR}feature_matrix_{{stat}}.parquet",
        stat=BENCH_STATS,
    )

rule all:
    input: TARGETS
